# KIS OpenAPI (한국투자증권)
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=your_account_number
KIS_MOCK=true  # true=모의투자, false=실투자

# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App Security (approval payload + user settings secret encryption)
APP_SECRET_KEY=change_this_to_a_long_random_secret
# Optional: 32-byte urlsafe-base64 Fernet key. If blank, derived from APP_SECRET_KEY.
DATA_ENCRYPTION_KEY=

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<db_password>@cluster0.cvctnz4.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=korean_trading_agents
MONGODB_CONNECT_TIMEOUT_MS=5000

# 기타 데이터 소스
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
