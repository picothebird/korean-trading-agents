# ─────────────────────────────────────────────────────────
# Korean Trading Agents — 환경 변수 (필수만 정리)
# ─────────────────────────────────────────────────────────

# [필수] LLM
OPENAI_API_KEY=your_openai_api_key_here

# [필수] KIS OpenAPI (한국투자증권)
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=your_account_number
KIS_MOCK=true   # true=모의투자, false=실투자

# [필수] MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<db_password>@<your-cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<your-app>
MONGODB_DB_NAME=korean_trading_agents

# [필수] App Security
# 두 키 모두 32바이트 이상 랜덤 문자열로 설정.
# DEBUG=false 환경에서는 부팅 시 dev-* / 빈 값을 거부한다.
APP_SECRET_KEY=change_this_to_a_long_random_secret_at_least_32_chars
# 32바이트 urlsafe-base64 Fernet 키
# 예: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=

# [필수] CORS — 콤마 구분, 운영 도메인 명시
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# [선택] 운영 모드 (false면 부팅 시 보안 키 검증 강제)
DEBUG=true

# [선택] DB 연결 타임아웃
MONGODB_CONNECT_TIMEOUT_MS=5000

# [선택] 보관 정책 (TTL)
ACTIVITY_LOG_RETENTION_DAYS=90
USER_TRADE_RETENTION_DAYS=365

# [선택] Rate limit / DoS
MAX_REQUEST_BODY_BYTES=1048576
RATE_LIMIT_LOGIN_PER_MIN=5
RATE_LIMIT_REGISTER_PER_MIN=3
RATE_LIMIT_ORDER_PER_MIN=10
RATE_LIMIT_ANALYSIS_PER_MIN=5

# [선택] 계정 잠금
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
